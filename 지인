    <title>Lucky's Friends!</title>
    <style>
        :root { --main: #00ff88; --bg: #121212; --card: #1e1e1e; }
        body { background: var(--bg); color: white; font-family: sans-serif; margin: 0; padding: 20px; text-align: center; }
        header { padding: 40px 0; border-bottom: 1px solid #333; }
        h1 { color: var(--main); margin: 0; font-size: 2rem; }
