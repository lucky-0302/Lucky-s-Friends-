        .card { background: var(--card); padding: 15px; border-radius: 12px; border: 1px solid #333; }
        .name { font-weight: bold; font-size: 1.1rem; display: block; }
        .tag { font-size: 0.8rem; color: var(--main); margin-top: 5px; opacity: 0.8; }
    </style>
</head>
